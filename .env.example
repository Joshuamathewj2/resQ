# ResQ Environment Configuration Template
# Copy this file to .env and fill in your keys.

# Google Gemini API Key (Required for AI analysis)
# Obtain from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Twilio Configuration (Optional - fallback mailto/tel used if empty)
# Obtain from: https://www.twilio.com/console
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
VITE_TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
